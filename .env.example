# Spring: spring.datasource.* 에 매핑 (bootRun 시 필수에 가깝습니다)
DB_URL=jdbc:postgresql://YOUR_NCP_POSTGRES_HOST:5432/YOUR_DB_NAME?sslmode=require
DB_USERNAME=YOUR_DB_USERNAME
DB_PASSWORD=YOUR_DB_PASSWORD

# 로컬에서 클라우드 RAG 임베딩 쓸 때 필수 — <공인IP> 를 NCP VM 공인 IP 로 바꿔 입력
RAG_EMBEDDING_BASE_URL=http://<공인IP>:8001

# 선택 — application.yaml 기본값 대신 쓰려면 설정
# POPPLY_BASE_URL=
# AI_FASTAPI_URL=http://127.0.0.1:8000/chat
